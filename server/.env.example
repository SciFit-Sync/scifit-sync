# Database
# 로컬 직접 실행(uvicorn): 아래 값 그대로 사용
# Docker Compose 실행: docker-compose.yml에서 자동으로 @db:5432로 덮어씀
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scifiitsync

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM
GEMINI_API_KEY=
OPENAI_API_KEY=          # GPT-4o-mini fallback

# 외부 API
KAKAO_REST_API_KEY=

# Admin API (mlops 적재용 X-Admin-Token 헤더 검증)
# 프로덕션은 AWS Secrets Manager로 ECS Task Def에 주입
ADMIN_API_TOKEN=

# ChromaDB
CHROMA_PERSIST_PATH=/chroma-data

# Rate Limiting (slowapi)
# true: auth 10/min, LLM 5/min, 일반 60/min / false: 무제한 (테스트 환경용)
RATE_LIMIT_ENABLED=true

# CORS — 쉼표 구분 문자열 또는 JSON 배열
# 프로덕션은 명시 도메인으로 제한 권장 (예: https://scifit-sync.com)
ALLOWED_ORIGINS=*

# 환경
ENV=development          # development | production
