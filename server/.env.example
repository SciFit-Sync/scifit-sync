# Database
# 로컬 직접 실행(uvicorn): 아래 값 그대로 사용
# Docker Compose 실행: docker-compose.yml에서 자동으로 @db:5432로 덮어씀
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scifiitsync

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# JWT
# 프로덕션 기동 가드: 최소 32자 + 알려진 placeholder 금지 (config.py model_post_init)
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM (services/llm.py)
GEMINI_API_KEY=
OPENAI_API_KEY=          # GPT-4o-mini fallback
LLM_PROVIDER=gemini      # 기본값 gemini | openai (openai 강제 전환용)
GEMINI_MODEL=gemini-2.5-flash   # 기본값
OPENAI_MODEL=gpt-4o-mini        # 기본값

# 외부 API
KAKAO_REST_API_KEY=
WORKOUTX_API_KEY=        # 운동 gif 영상 API — 미설정 시 WorkoutX 호출·gif 프록시 건너뜀

# 서버 자기 공개 base URL (gif 프록시 등 절대 URL 생성용)
# 기본값 https://scifit-sync.com / 로컬 dev: http://localhost:8000
PUBLIC_BASE_URL=https://scifit-sync.com

# Admin API (mlops 적재용 X-Admin-Token 헤더 검증)
# 프로덕션은 AWS Secrets Manager로 ECS Task Def에 주입
ADMIN_API_TOKEN=

# ChromaDB (services/rag.py)
CHROMA_PERSIST_PATH=/chroma-data
# 운영 컬렉션 SOT는 EFS /chroma-data/current_alias.json (alias-swap) — 아래는 fallback 기본값
CHROMA_COLLECTION_NAME=paper_chunks
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5   # 기본값

# AWS SES (이메일 OTP 발송)
# ⚠️ 현재 미사용 (SES 샌드박스·프로덕션 심사 거절) — 실제 OTP 발송 경로는 아래 Gmail SMTP
# ECS 프로덕션: IAM Role 사용 시 ACCESS_KEY/SECRET 불필요 (비워두면 자동)
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=           # 예: noreply@scifit-sync.com (SES에서 인증된 이메일)

# Rate Limiting (slowapi)
# true: auth 10/min, LLM 5/min, 일반 60/min / false: 무제한 (테스트 환경용)
RATE_LIMIT_ENABLED=true

# CORS — 쉼표 구분 문자열 또는 JSON 배열
# 프로덕션은 명시 도메인으로 제한 권장 (예: https://scifit-sync.com)
ALLOWED_ORIGINS=*

# Email (Gmail SMTP) — OTP 실제 발송 경로 (core/email.py)
# 프로덕션에서 OTP 실발송에 필수 — 미설정 또는 ENV=development면 로그 출력으로 대체
# 발급: Google 계정 → 보안 → 2단계 인증 → 앱 비밀번호 (16자리)
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# 기본값 있는 키 (변경 시에만 설정)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_FROM_NAME=SciFit-Sync

# 환경
ENV=development          # development | production
