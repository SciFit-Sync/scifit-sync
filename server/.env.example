# Database
# 로컬 직접 실행(uvicorn): localhost
# Docker Compose 실행: db (docker-compose.yml 서비스명)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/scifiitsync

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM
GEMINI_API_KEY=
OPENAI_API_KEY=          # GPT-4o-mini fallback

# 외부 API
KAKAO_REST_API_KEY=

# ChromaDB
CHROMA_PERSIST_PATH=/chroma-data

# 환경
ENV=development          # development | production
