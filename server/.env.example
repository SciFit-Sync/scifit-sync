# Database
# 로컬 직접 실행(uvicorn): 아래 값 그대로 사용
# Docker Compose 실행: docker-compose.yml에서 자동으로 @db:5432로 덮어씀
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scifiitsync

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# JWT
JWT_SECRET_KEY=your-secret-key-here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# LLM
GEMINI_API_KEY=
OPENAI_API_KEY=          # GPT-4o-mini fallback

# 외부 API
KAKAO_REST_API_KEY=

# ChromaDB
CHROMA_PERSIST_PATH=/chroma-data

# AWS SES (이메일 OTP 발송)
# ECS 프로덕션: IAM Role 사용 시 ACCESS_KEY/SECRET 불필요 (비워두면 자동)
# 로컬 개발: SES_FROM_EMAIL 미설정 시 콘솔 로그로 대체
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_EMAIL=           # 예: noreply@scifit-sync.com (SES에서 인증된 이메일)

# 환경
ENV=development          # development | production
