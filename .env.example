# ── PubMed / NCBI ──────────────────────────────────────────
NCBI_API_KEY=your_ncbi_api_key_here

# PMC 전문 수집 retry 정책
NCBI_HTTP_MAX_RETRIES=5
NCBI_HTTP_MAX_BACKOFF=10.0
NCBI_HTTP_TIMEOUT=60
PMC_FULLTEXT_MAX_ATTEMPTS=3
PMC_FULLTEXT_RETRY_BACKOFF_BASE=2.0
PMC_FULLTEXT_RETRY_BACKOFF_MAX=10.0

# ── Embedding / ChromaDB ────────────────────────────────────
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
CHROMA_PERSIST_PATH=/chroma-data
CHROMA_COLLECTION_NAME=paper_chunks

# ── 청킹 ──────────────────────────────────────────────────
CHUNK_MIN_TOKENS=300
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# ── 파이프라인 ────────────────────────────────────────────
MAX_PAPERS_PER_RUN=300
MAX_PAPERS_PER_CATEGORY=20

# ── API 연동 (GitHub Actions → 서버 ChromaDB 적재) ─────────
# 프로덕션: https://scifit-sync.com (도메인 + ACM HTTPS 적용됨)
# 로컬 mlops 실행: http://localhost:8000
API_BASE_URL=https://scifit-sync.com
ADMIN_API_TOKEN=your_admin_api_token_here

# OpenAlex (다중 소스 논문 수집)
OPENALEX_BASE_URL=https://api.openalex.org
# 필수: OpenAlex polite pool 등록용 — 본인 이메일로 교체
OPENALEX_MAILTO=team@scifit-sync.example
OPENALEX_MAX_PER_CATEGORY=500
PUBMED_MAX_PER_CATEGORY=50

# Europe PMC (PMC 본문 실패 시 fallback)
EUROPEPMC_BASE_URL=https://www.ebi.ac.uk/europepmc/webservices/rest
EUROPEPMC_RATE_LIMIT=1.0

# false: 다소스 본문 보강 + 가중치 정렬 / true: legacy PubMed strict 필터만
STRICT_PUBLICATION_FILTER=false


# ═══════════════════════════════════════════════════════════════════
# 서버(FastAPI) 환경변수 — ECS Task Definition에 그대로 매핑
# ═══════════════════════════════════════════════════════════════════

# ── Environment (fail-safe: 미설정 시 production) ───────────────
# development / production / test
ENV=development

# ── Database ────────────────────────────────────────────────────
# Supabase Postgres asyncpg 연결 (로컬 dev는 docker-compose의 db 컨테이너)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/scifiitsync

# Supabase 메타 (선택 — 현재 코드는 DATABASE_URL만 사용)
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── JWT ─────────────────────────────────────────────────────────
# 프로덕션 필수: 최소 32자, 알려진 placeholder 금지 (config.py model_post_init 검증)
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── LLM (Gemini 2.5 Flash → GPT-4o-mini fallback) ───────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── External API ────────────────────────────────────────────────
# 카카오 로컬 API (헬스장 검색 프록시)
KAKAO_REST_API_KEY=

# ── Rate Limiting (slowapi) ─────────────────────────────────────
# true: auth 10/min, LLM 5/min, 일반 60/min 적용 / false: 전부 무제한 (테스트 환경용)
RATE_LIMIT_ENABLED=true

# ── CORS ────────────────────────────────────────────────────────
# 쉼표 구분 문자열 또는 JSON 배열. 프로덕션은 명시 도메인으로 제한 권장
# 예: ALLOWED_ORIGINS=https://app.scifit-sync.example,https://admin.scifit-sync.example
ALLOWED_ORIGINS=*
